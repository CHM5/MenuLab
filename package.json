{
  "name": "showy-inborn-stork",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testEnvironment": "jest-environment-jsdom",
    "testMatch": ["**/tests/**/*.test.js"],
    "testPathIgnorePatterns": ["/node_modules/", "/menulab-editor/"],
    "modulePathIgnorePatterns": ["/menulab-editor/"],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "script.js",
      "form.js",
      "plansForm.js",
      "plansForm1.js"
    ]
  },
  "dependencies": {
    "parcel-bundler": "^1.6.1",
    "next": "^12.1.10",
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0"
  }
}
